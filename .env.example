# =============================================================================
# LittleBundle Diaper Store — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the app.
# All variables marked [REQUIRED] must be set for the app to function.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Prisma)  [REQUIRED]
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by Prisma ORM.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?connect_timeout=15
# For Vercel, use a managed PostgreSQL provider such as:
#   - Vercel Postgres (built-in)
#   - Neon (https://neon.tech)
#   - Supabase (https://supabase.com)
#   - Railway (https://railway.app)
DATABASE_URL="postgresql://user:password@host:5432/dbname?connect_timeout=15&pool_timeout=15&connection_limit=3"

# Direct database connection (without connection pooling), used by Prisma for migrations.
# This can be the same as DATABASE_URL if you don't use a connection pooler like PgBouncer.
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname?connect_timeout=15"

# -----------------------------------------------------------------------------
# Site URL  [RECOMMENDED]
# -----------------------------------------------------------------------------
# Used for generating canonical URLs in metadata, sitemap.xml, and robots.txt.
# Set this to your production domain on Vercel (e.g., https://your-store.vercel.app).
# Falls back to http://localhost:3000 if not set.
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Discord Webhook  [OPTIONAL]
# -----------------------------------------------------------------------------
# Discord webhook URL for order notifications
# If not set, Discord notifications will not be sent
# Format: https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
DISCORD_WEBHOOK_URL=""

# =============================================================================